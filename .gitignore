# Rootstack .gitignore
# Only local machine state is excluded.
# Personal content (journals, notes, filled-in profile files) is YOUR responsibility
# to manage — if you don't want it on GitHub, don't push it.

# ── Local state ───────────────────────────────────────────────
.rootstack/
.claude/settings.local.json
.claude/scheduled_tasks.lock

# ── Raw session transcripts (can be large) ────────────────────
Knowledge Base/Raw/Sessions/*.jsonl

# ── Obsidian ──────────────────────────────────────────────────
.obsidian/workspace.json
.obsidian/plugins/journals/main.js
.obsidian/plugins/journals/styles.css

# ── System files ──────────────────────────────────────────────
desktop.ini
.DS_Store
*.tmp
